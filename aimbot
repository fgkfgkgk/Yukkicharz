------------------------------------------------
-- Перетаскивание меню
------------------------------------------------
local isDragging = false
local dragStartInputPos = Vector2.zero
local dragStartFramePos = Vector2.zero

UIS.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	local inputType = input.UserInputType
	if inputType ~= Enum.UserInputType.MouseButton1 and
		inputType ~= Enum.UserInputType.MouseButton3 and
		inputType ~= Enum.UserInputType.Touch then return end

	local objects = ScreenGui:GetGuiObjectsAtPosition(input.Position.X, input.Position.Y)
	local clickedGui = nil
	for _, obj in ipairs(objects) do
		if obj:IsA("GuiButton") then clickedGui = obj; break end
	end
	if clickedGui and clickedGui:IsDescendantOf(Frame) then
		if clickedGui == DragButton then
			isDragging = true
			dragStartInputPos = input.Position
			dragStartFramePos = Frame.AbsolutePosition
		end
		return
	end

	if inputType == Enum.UserInputType.MouseButton1 then
		aimbotEnabled = true
		updateButtons()
	elseif inputType == Enum.UserInputType.MouseButton3 then
		aimbotEnabled = false
		currentTarget = nil
		updateButtons()
	end
end)

UIS.InputChanged:Connect(function(input)
	if not isDragging then return end
	if input.UserInputType == Enum.UserInputType.MouseMovement or
		input.UserInputType == Enum.UserInputType.Touch then
		local delta = input.Position - dragStartInputPos
		Frame.Position = UDim2.new(0, dragStartFramePos.X + delta.X, 0, dragStartFramePos.Y + delta.Y)
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or
		input.UserInputType == Enum.UserInputType.Touch then
		isDragging = false
	end
end)

