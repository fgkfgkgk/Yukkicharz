end)

------------------------------------------------
-- Получение части для прицеливания
------------------------------------------------
local function getTargetPart(model)
	return model:FindFirstChild("Head") or model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart
end

------------------------------------------------
-- Поиск цели (NPC: от меньшего роста к большему)
------------------------------------------------
local function updateBestTarget()
	bestTarget = nil
	local character = LocalPlayer.Character
	if not character then return end
	local localRoot = character:FindFirstChild("HumanoidRootPart")
	if not localRoot then return end

	local localTeam = LocalPlayer.Team

	if targetMode == "NPC" then
		-- Сортируем по реальному росту модели (bounding box): чем меньше рост, тем приоритетнее
		local bestHeight = math.huge
		for model, _ in pairs(targets) do
			if not model or not model.Parent then
				targets[model] = nil
				continue
			end
			local humanoid = model:FindFirstChildOfClass("Humanoid")
			if not humanoid or humanoid.Health <= 0 then
				targets[model] = nil
				continue
			end
			-- Пропускаем игроков в режиме NPC
			if Players:GetPlayerFromCharacter(model) then continue end

			local targetPart = getTargetPart(model)
			if not targetPart then continue end

			-- Проверка дистанции (чтобы не целиться в бесконечно далёких)
			local root = model:FindFirstChild("HumanoidRootPart") or targetPart
			local dist = (localRoot.Position - root.Position).Magnitude
			if dist > MAX_DISTANCE then continue end

			-- Реальная высота персонажа (размер ограничивающей рамки)
			local height = model:GetExtentsSize().Y
			if height <= 0 then continue end -- игнорируем некорректные модели

			if height < bestHeight then
				bestHeight = height
				bestTarget = targetPart
			end
		end
	else
		-- Остальные режимы: ближайшая цель
		local closestDist = MAX_DISTANCE
		for model, _ in pairs(targets) do
			if not model or not model.Parent then
				targets[model] = nil
				continue
			end
			local humanoid = model:FindFirstChildOfClass("Humanoid")
			if not humanoid or humanoid.Health <= 0 then
				targets[model] = nil
				continue
			end
			local targetPart = getTargetPart(model)
			if not targetPart then continue end

			local player = Players:GetPlayerFromCharacter(model)
			local isPlayer = player ~= nil

			if targetMode == "Players" then
				if not isPlayer then continue end
			elseif targetMode == "Teammates" then
				if not isPlayer then continue end
				if not localTeam or player.Team ~= localTeam then continue end
			elseif targetMode == "Enemies" then
				if not isPlayer then continue end
				if localTeam and player.Team == localTeam then continue end
			end

			local dist = (localRoot.Position - targetPart.Position).Magnitude
			if dist < closestDist then
				closestDist = dist
				bestTarget = targetPart
			end
		end
	end
end

------------------------------------------------
-- Обновление цели с интервалом
------------------------------------------------
task.spawn(function()
	while true do
		updateBestTarget()
		task.wait(UPDATE_INTERVAL)
	end
end)

------------------------------------------------
-- Aimbot (каждый кадр)
------------------------------------------------
RunService.RenderStepped:Connect(function()
	if not aimbotEnabled then
		currentTarget = nil
		return
	end

	if currentTarget and currentTarget.Parent then
		local humanoid = currentTarget.Parent:FindFirstChildOfClass("Humanoid")
		if not humanoid or humanoid.Health <= 0 then
			currentTarget = nil
		end
	else
		currentTarget = nil
	end

	if not currentTarget then
		currentTarget = bestTarget
	end

	if currentTarget then
		local camera = workspace.CurrentCamera
		if not camera then return end

		local camPos = camera.CFrame.Position
		local targetPos = currentTarget.Position
		camera.CFrame = CFrame.lookAt(camPos, targetPos)
	end
end)
