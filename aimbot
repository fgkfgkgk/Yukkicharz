local function addCharacter(model)
	if not model:IsA("Model") then return end
	if model == LocalPlayer.Character then return end
	if targets[model] then return end
	local humanoid = model:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end
	targets[model] = true
end

local function removeCharacter(model)
	targets[model] = nil
end

-- Стартовый скан
task.wait(1)
for _, obj in ipairs(workspace:GetDescendants()) do
	addCharacter(obj)
end

workspace.DescendantAdded:Connect(addCharacter)
workspace.DescendantRemoving:Connect(removeCharacter)

