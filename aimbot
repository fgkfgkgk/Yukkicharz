local function updateButtons()
	if targetMode == "NPC" then
		NPCButton.BackgroundColor3 = Color3.fromRGB(0,170,0)
		PlayerFilterButton.BackgroundColor3 = Color3.fromRGB(40,40,40)
	else
		NPCButton.BackgroundColor3 = Color3.fromRGB(40,40,40)
		if targetMode == "Players" then
			PlayerFilterButton.BackgroundColor3 = Color3.fromRGB(0,150,255)
			PlayerFilterButton.Text = "ALL PLAYERS"
		elseif targetMode == "Teammates" then
			PlayerFilterButton.BackgroundColor3 = Color3.fromRGB(0,170,0)
			PlayerFilterButton.Text = "TEAMMATES"
		elseif targetMode == "Enemies" then
			PlayerFilterButton.BackgroundColor3 = Color3.fromRGB(255,50,50)
			PlayerFilterButton.Text = "ENEMIES"
		end
	end
	if aimbotEnabled then
		ToggleButton.Text = "ON"
		ToggleButton.BackgroundColor3 = Color3.fromRGB(0,170,0)
	else
		ToggleButton.Text = "OFF"
		ToggleButton.BackgroundColor3 = Color3.fromRGB(170,0,0)
	end
end

